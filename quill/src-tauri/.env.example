# ─────────────────────────────────────────────────────────────────────────────
# Quill's own LLM (inline drafts, chat, wiki/style distillation).
# OpenAI-COMPATIBLE chat-completions endpoint. Uncomment ONE block below.
#
#   • Dev:            copy to  quill/src-tauri/.env
#   • Packaged .app:  copy to  ~/Library/Application Support/com.danishalisiddiqui.quill/.env
#
# NOTE: Quill runs on the HOST, so local Ollama is `localhost` here
#       (the sidecar runs in Docker, so ITS .env uses host.docker.internal instead).
# ─────────────────────────────────────────────────────────────────────────────

# (A) QUICK START — OpenAI:
QUILL_LLM_URL=https://api.openai.com/v1/chat/completions
QUILL_LLM_KEY=sk-REPLACE_WITH_YOUR_OPENAI_KEY
QUILL_LLM_MODEL=gpt-4o-mini

# (B) PRIVACY — local Ollama (needs `ollama pull qwen2.5:14b`):
# QUILL_LLM_URL=http://localhost:11434/v1/chat/completions
# QUILL_LLM_KEY=ollama
# QUILL_LLM_MODEL=qwen2.5:14b

# (C) ADVANCED — your own OpenAI-compatible server:
# QUILL_LLM_URL=https://<your-host>/v1/chat/completions
# QUILL_LLM_KEY=<key>
# QUILL_LLM_MODEL=<model-id-or-path>
