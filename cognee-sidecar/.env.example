# ─────────────────────────────────────────────────────────────────────────────
# Cognee sidecar config — the "memory engine". Copy this file to `.env`, then
# uncomment ONE of the LLM blocks below (A quick-start, B privacy, or C advanced).
#   cp cognee-sidecar/.env.example cognee-sidecar/.env
# NOTE: leave values UNQUOTED in the real .env (pydantic rejects quoted paths).
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM (graph-building / cognify) — pick ONE ────────────────────────────────

# (A) QUICK START — OpenAI. Paste your key; it also powers embeddings below.
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=sk-REPLACE_WITH_YOUR_OPENAI_KEY

# (B) PRIVACY — 100% local via Ollama (nothing leaves your machine).
#     Needs Ollama running on the host + `ollama pull qwen2.5:14b`.
# LLM_PROVIDER=ollama
# LLM_MODEL=ollama/qwen2.5:14b
# LLM_ENDPOINT=http://host.docker.internal:11434

# (C) ADVANCED — your own OpenAI-compatible server (e.g. self-hosted vLLM).
# LLM_PROVIDER=custom
# LLM_MODEL=hosted_vllm/<your-model-name>
# LLM_ENDPOINT=https://<your-vllm-host>/v1
# LLM_API_KEY=<key or . if none>

LLM_INSTRUCTOR_MODE=json_schema_mode

# Throttle cognify so background graph-building never starves interactive drafting.
LLM_RATE_LIMIT_ENABLED=true
LLM_RATE_LIMIT_REQUESTS=15
LLM_RATE_LIMIT_INTERVAL=60

# ── Embeddings — match your LLM choice above ─────────────────────────────────

# (A) OpenAI embeddings (pairs with the OpenAI quick-start; reuse the same key):
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
EMBEDDING_API_KEY=sk-REPLACE_WITH_YOUR_OPENAI_KEY

# (B) Local Ollama embeddings (pairs with the Ollama privacy option):
#     Needs `ollama pull nomic-embed-text`.
# EMBEDDING_PROVIDER=ollama
# EMBEDDING_MODEL=nomic-embed-text:latest
# EMBEDDING_ENDPOINT=http://host.docker.internal:11434/api/embed
# EMBEDDING_DIMENSIONS=768

# ── Storage (leave as-is) ────────────────────────────────────────────────────
GRAPH_DATABASE_PROVIDER=kuzu
VECTOR_DB_PROVIDER=lancedb
DB_PROVIDER=sqlite
SYSTEM_ROOT_DIRECTORY=/data/.cognee_system
DATA_ROOT_DIRECTORY=/data/.data_storage
